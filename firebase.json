{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/html; charset=UTF-8"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      "fix.js",
      "update_portfolio_cards.py",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}
